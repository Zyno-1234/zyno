generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Building {
  id             Int      @id @default(autoincrement())

  name           String
  code           String   @unique

  address        String
  city           String
  state          String
  pincode        String

  managerName    String?
  managerPhone   String?

  rooms          Room[]

  createdAt      DateTime @default(now())
}

model Room {
  id          Int      @id @default(autoincrement())
  roomNumber  String
  roomType    String
  sharing     Int

  buildingId  Int
  building    Building @relation(fields: [buildingId], references: [id])

  beds        Bed[]
}

model Bed {
  id        Int @id @default(autoincrement())
  bedNumber String

  roomId    Int
  room      Room @relation(fields: [roomId], references: [id])

  tenant    Tenant?
}

model Tenant {
  id               Int      @id @default(autoincrement())
  fullName         String
  phone            String
  email            String?
  gender           String
  company          String?
  employeeId       String?
  moveInDate       DateTime
  emergencyContact String?
  remarks          String?

  bedId            Int      @unique
  bed              Bed      @relation(fields: [bedId], references: [id])

  createdAt        DateTime @default(now())
}